{
  "expo": {
    "name": "FirstExpoApp",
    "slug": "FirstExpoApp",
    "version": "1.0.0",
    "scheme": "firstexpoapp",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
        "supportsTablet": true,
        "bundleIdentifier": "com.anonymous.FirstExpoApp",
        "infoPlist": {
            "UIBackgroundModes": [
                "fetch",
                "remote-notification",
                "processing"
            ]
        }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
        "predictiveBackGestureEnabled": false,
        "package": "com.anonymous.FirstExpoApp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-router",
        "expo-notifications",
        "expo-background-task",
        "expo-task-manager",
        "@react-native-community/datetimepicker",
        "expo-background-task"
    ]
  }
}
